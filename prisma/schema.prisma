generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tournament {
  id        String    @id @default(cuid())
  name      String
  year      Int
  teamCount Int
  startsAt  DateTime
  endsAt    DateTime
  status    String    @default("scheduled")
  teams     Team[]
  fixtures  Fixture[]
  pools     Pool[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Team {
  id           String           @id @default(cuid())
  tournamentId String
  name         String
  displayName  String
  isoCode      String
  flagCode     String
  confederation String
  fifaRanking  Int
  groupCode    String
  status       String           @default("not_started")
  tournament   Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  homeFixtures Fixture[]        @relation("HomeTeam")
  awayFixtures Fixture[]        @relation("AwayTeam")
  wonFixtures  Fixture[]        @relation("WinnerTeam")
  assignments  DrawAssignment[]
  unassigned   UnassignedTeam[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([tournamentId, name])
}

model Fixture {
  id           String     @id @default(cuid())
  tournamentId String
  homeTeamId   String
  awayTeamId   String
  winnerTeamId String?
  matchNumber  Int
  stage        String
  groupCode    String?
  venue        String?
  city         String?
  startsAt     DateTime
  homeScore    Int?
  awayScore    Int?
  status       String     @default("scheduled")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  homeTeam     Team       @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam     Team       @relation("AwayTeam", fields: [awayTeamId], references: [id])
  winnerTeam   Team?      @relation("WinnerTeam", fields: [winnerTeamId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([tournamentId, matchNumber])
}

model Pool {
  id                         String           @id @default(cuid())
  tournamentId               String
  name                       String
  adminName                  String
  adminCode                  String           @unique
  joinCode                   String           @unique
  setupMode                  String           @default("quick")
  playerCap                  Int?
  minimumPlayers             Int              @default(2)
  drawDeadline               DateTime?
  drawStatus                 String           @default("waiting")
  drawStartedAt              DateTime?
  drawCompletedAt            DateTime?
  allowPlayerLeave           Boolean          @default(true)
  allowPlayerNameEdit        Boolean          @default(true)
  showPlayerListBeforeDraw   Boolean          @default(true)
  resultsVisibility          String           @default("public_after_draw")
  paymentEnabled             Boolean          @default(false)
  entryFeeAmount             String?
  currency                   String?
  paymentAccountHolder       String?
  paymentBankName            String?
  paymentAccountNumber       String?
  paymentBranchCode          String?
  paymentReference           String?
  paymentNote                String?
  prizeStructureJson         String?
  rulesNote                  String?
  tournament                 Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  players                    Player[]
  draws                      Draw[]
  assignments                DrawAssignment[]
  unassignedTeams            UnassignedTeam[]
  auditEvents                AuditEvent[]
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
}

model Player {
  id                String           @id @default(cuid())
  poolId            String
  displayName       String
  accessCode        String
  isAdmin           Boolean          @default(false)
  paidStatus        String           @default("unpaid")
  hasViewedReveal   Boolean          @default(false)
  pool              Pool             @relation(fields: [poolId], references: [id], onDelete: Cascade)
  assignments       DrawAssignment[]
  auditEvents       AuditEvent[]
  joinedAt          DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([poolId, accessCode])
}

model Draw {
  id               String           @id @default(cuid())
  poolId           String
  drawNumber       Int
  status           String           @default("complete")
  algorithmVersion String
  randomSeedHash   String
  createdByAdmin   Boolean          @default(true)
  pool             Pool             @relation(fields: [poolId], references: [id], onDelete: Cascade)
  assignments      DrawAssignment[]
  unassignedTeams  UnassignedTeam[]
  createdAt        DateTime         @default(now())
  completedAt      DateTime?

  @@unique([poolId, drawNumber])
}

model DrawAssignment {
  id          String   @id @default(cuid())
  drawId      String
  poolId      String
  playerId    String
  teamId      String
  rankingBand Int
  revealOrder Int
  draw        Draw     @relation(fields: [drawId], references: [id], onDelete: Cascade)
  pool        Pool     @relation(fields: [poolId], references: [id], onDelete: Cascade)
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([drawId, teamId])
}

model UnassignedTeam {
  id        String   @id @default(cuid())
  drawId    String
  poolId    String
  teamId    String
  reason    String
  draw      Draw     @relation(fields: [drawId], references: [id], onDelete: Cascade)
  pool      Pool     @relation(fields: [poolId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([drawId, teamId])
}

model AuditEvent {
  id           String   @id @default(cuid())
  poolId       String
  actorType    String
  actorId      String?
  eventType    String
  eventPayload String?
  pool         Pool     @relation(fields: [poolId], references: [id], onDelete: Cascade)
  player       Player?  @relation(fields: [actorId], references: [id])
  createdAt    DateTime @default(now())
}
